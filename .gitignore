### Stockfish / Executables ###
# Binaries are downloaded by Maven profiles (mvn package -Pwindows or -Plinux)
# Never commit binary files to the repository
server/stockfish/stockfish
server/stockfish/stockfish.exe
server/stockfish/stockfish-*
server/stockfish/*.exe
server/stockfish/*.bin
# Keep the directory tracked by git
!server/stockfish/.gitkeep

