# Database configuration
POSTGRES_DB=<database-name>
POSTGRES_USER=<database-username>
POSTGRES_PASSWORD=<database-password>

# Spring datasource configuration
SPRING_DATASOURCE_URL=<jdbc-database-url>
SPRING_DATASOURCE_USERNAME=<database-username>
SPRING_DATASOURCE_PASSWORD=<database-password>

# Flyway migration configuration
SPRING_FLYWAY_URL=<jdbc-database-url>
SPRING_FLYWAY_USER=<database-username>
SPRING_FLYWAY_PASSWORD=<database-password>

# Production safety
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Stockfish runtime configuration
STOCKFISH_PATH=stockfish/stockfish

# Match engine configuration
GAME_MOVE_THINK_TIME_MILLIS=250
GAME_MAX_PLIES=300
